# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
BAILIAN_API_KEY=

# Bailian Coding Plan (optional)
# Get your Coding Plan API key from: https://modelstudio.console.aliyuncs.com
# API keys start with 'sk-sp-' and use dedicated endpoint
BAILIAN_CODING_PLAN_API_KEY=
# Set to 'true' to force Coding Plan mode (optional, auto-detected from API key)
BAILIAN_CODING_PLAN_ENABLED=false
